{
  "info": {
    "name": "Booking Tours API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8090"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "categoryId",
      "value": ""
    },
    {
      "key": "tourId",
      "value": ""
    },
    {
      "key": "imageId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Test User\",\n  \"email\": \"test@gmail.com\",\n  \"password\": \"123456\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@gmail.com\",\n  \"password\": \"123456\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/refresh",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/admin/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@sun.com\",\n  \"password\": \"Admin@123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/logout",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "User Profile",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/users/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/users/me",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Nguyen Van A\",\n  \"phone\": \"0912345678\",\n  \"avatarUrl\": \"https://example.com/avatar.jpg\"\n}"
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/users/me/password",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oldPassword\": \"123456\",\n  \"newPassword\": \"newpass123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Bank Accounts",
      "item": [
        {
          "name": "Get All Bank Accounts",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/users/me/bank-accounts",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Create Bank Account",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/users/me/bank-accounts",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bankName\": \"Vietcombank\",\n  \"accountNumber\": \"1234567890\",\n  \"accountHolder\": \"NGUYEN VAN A\"\n}"
            }
          }
        },
        {
          "name": "Update Bank Account",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/users/me/bank-accounts/:id",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bankName\": \"Techcombank\",\n  \"accountNumber\": \"9876543210\",\n  \"accountHolder\": \"NGUYEN VAN A\"\n}"
            }
          }
        },
        {
          "name": "Delete Bank Account",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/users/me/bank-accounts/:id",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Set Default Bank Account",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/users/me/bank-accounts/:id/default",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get Category Tree (Public)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/categories"
          }
        },
        {
          "name": "Create Category (Admin)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/admin/categories",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Du lịch biển\",\n  \"description\": \"Các tour du lịch biển đảo\",\n  \"parentId\": null\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) {",
                  "  pm.collectionVariables.set('categoryId', res.data.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Child Category (Admin)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/admin/categories",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Phú Quốc\",\n  \"description\": \"Tour Phú Quốc\",\n  \"parentId\": \"{{categoryId}}\"\n}"
            }
          }
        },
        {
          "name": "Update Category (Admin)",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/admin/categories/{{categoryId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Du lịch biển đảo\",\n  \"description\": \"Cập nhật mô tả\"\n}"
            }
          }
        },
        {
          "name": "Delete Category (Admin)",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/admin/categories/{{categoryId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Tours (Admin)",
      "item": [
        {
          "name": "Create Tour",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/admin/tours",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Tour Hạ Long 3 ngày 2 đêm\",\n  \"description\": \"Khám phá vịnh Hạ Long kỳ vĩ với các hang động và đảo đẹp\",\n  \"thumbnailUrl\": \"https://example.com/halong.jpg\",\n  \"basePrice\": 3500000,\n  \"durationDays\": 3,\n  \"maxParticipants\": 30,\n  \"departureLocation\": \"Hà Nội\",\n  \"categoryId\": \"{{categoryId}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) {",
                  "  pm.collectionVariables.set('tourId', res.data.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Tour",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/admin/tours/{{tourId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Tour Hạ Long 3 ngày 2 đêm - Cao cấp\",\n  \"description\": \"Trải nghiệm du thuyền 5 sao trên vịnh Hạ Long\",\n  \"thumbnailUrl\": \"https://example.com/halong-luxury.jpg\",\n  \"basePrice\": 5000000,\n  \"durationDays\": 3,\n  \"maxParticipants\": 20,\n  \"departureLocation\": \"Hà Nội\",\n  \"categoryId\": \"{{categoryId}}\"\n}"
            }
          }
        },
        {
          "name": "Update Tour Status",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/admin/tours/{{tourId}}/status",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ACTIVE\"\n}"
            }
          }
        },
        {
          "name": "Add Images",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/admin/tours/{{tourId}}/images",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"imageUrls\": [\n    \"https://example.com/halong-1.jpg\",\n    \"https://example.com/halong-2.jpg\",\n    \"https://example.com/halong-3.jpg\"\n  ]\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.images && res.data.images.length > 0) {",
                  "  pm.collectionVariables.set('imageId', res.data.images[0].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Image",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/admin/tours/{{tourId}}/images/{{imageId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ]
          }
        },
        {
          "name": "Update Places",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/admin/tours/{{tourId}}/places",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ids\": []\n}"
            }
          }
        },
        {
          "name": "Update Foods",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/admin/tours/{{tourId}}/foods",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ids\": []\n}"
            }
          }
        },
        {
          "name": "Delete Tour",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/admin/tours/{{tourId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ]
          }
        }
      ]
    }
  ]
}
