              ]
            }
          }]
        },
        {
          "name": "Update Schedule",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/admin/schedules/{{scheduleId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"departureDate\": \"2025-06-05\",\n  \"returnDate\": \"2025-06-07\",\n  \"totalSlots\": 25,\n  \"priceOverride\": 4000000\n}"
            }
          }
        },
        {
          "name": "Update Schedule Status",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/admin/schedules/{{scheduleId}}/status",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CANCELLED\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Tours (Public)",
      "item": [
        {
          "name": "List Tours",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/tours?page=0&size=10&sort=createdAt,desc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tours"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "sort", "value": "createdAt,desc" },
                { "key": "categoryId", "value": "", "disabled": true },
                { "key": "minPrice", "value": "", "disabled": true },
                { "key": "maxPrice", "value": "", "disabled": true },
                { "key": "durationDays", "value": "", "disabled": true },
                { "key": "departureLocation", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Search Tours",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/tours/search?q=Hạ Long&page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tours", "search"],
              "query": [
                { "key": "q", "value": "Hạ Long" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Tour Detail",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/tours/{{tourSlug}}"
          }
        },
        {
          "name": "Get Tour Reviews",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/tours/{{tourSlug}}/reviews?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tours", "{{tourSlug}}", "reviews"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create Booking",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/bookings",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"scheduleId\": \"{{scheduleId}}\",\n  \"numParticipants\": 2\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const res = pm.response.json();",
                "if (res.data) { pm.collectionVariables.set('bookingId', res.data.id); }"
              ]
            }
          }]
        },
        {
          "name": "Get My Bookings",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/bookings?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bookings"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "status", "value": "PENDING", "disabled": true }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Get Booking By Id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/bookings/{{bookingId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Cancel Booking",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/bookings/{{bookingId}}/cancel",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cancelReason\": \"Thay đổi kế hoạch cá nhân\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Payments",
